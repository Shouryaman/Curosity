# Copy to ".env" in this folder and fill in your key.
# https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-your-key-here

# Dev tip: Deployments uses the Vite proxy to port 8000. If you see HTTP 502,
# the API is not running. From repo root use:
#   npm run stack     → starts FastAPI + Vite together (recommended)
# or two terminals:   npm run api   and   npm run dev

# Performance / reliability (defaults are set in code if unset):
#
# Pipeline (default: artifacts = design + backend + output/app.py, no unit-test agent):
#   minimal — design + backend module only
#   artifacts — design + backend + Gradio app.py (files only)
#   full — includes test_{module} task
# ENGINEERING_TEAM_PIPELINE=artifacts
#
# Shorter run when you only need the Python module (no Gradio file):
# ENGINEERING_TEAM_PIPELINE=minimal
#
# Hard wall-clock limit for an entire crew run (seconds). Default 180 (3 min).
# ENGINEERING_TEAM_CREW_MAX_SEC=180
#
# Per LLM HTTP call timeout (seconds). Default 180.
# ENGINEERING_TEAM_LLM_TIMEOUT_SEC=180
#
# Cap completion length per call. Default 4096.
# ENGINEERING_TEAM_LLM_MAX_TOKENS=4096
#
# Model id for LiteLLM (same format as before: provider/model).
# ENGINEERING_TEAM_MODEL=openai/gpt-4o-mini
#
# Max agent reasoning loop iterations per task. Default 10.
# ENGINEERING_TEAM_AGENT_MAX_ITER=10

# Empty output/ before each crew run so Deployments only lists this run's files.
# Set to 0 to keep previous artifacts (not recommended).
# ENGINEERING_TEAM_CLEAR_OUTPUT_BEFORE_RUN=1

# Optional: when using `npm run api`, mirror CrewAI / LiteLLM log lines to the
# terminal (they still stream to the app UI via SSE).
# ENGINEERING_TEAM_CREW_LOG_TERMINAL=1

# Optional frontend (create frontend/.env.local): after a successful crew run,
# auto-navigate to Deployments. Default is off — you stay on Builders with file paths in logs.
# VITE_NAVIGATE_AFTER_RUN=1
